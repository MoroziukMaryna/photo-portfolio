---
// логіка та імпорти на TypeScript
import '../styles/global.css';
const photographerName = "Portfolio Showcase";
---

<html lang="uk">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{photographerName}</title>
  </head>
  <body class="bg-neutral-900 text-white min-h-screen flex flex-col items-center justify-center p-4">
    <main class="text-center space-y-4">
      <h1 class="text-4xl md:text-6xl font-light tracking-wider">
        {photographerName}
      </h1>
      <p class="text-neutral-400 text-lg">
        Сайт-візитка фотографа • Скоро тут буде краса
      </p>
      <div class="pt-4">
        <span class="px-4 py-2 bg-neutral-800 rounded-full border border-neutral-700 text-sm text-neutral-300">
          Astro + Tailwind CSS Ready
        </span>
      </div>
    </main>
  </body>
</html>