---
import { sanityClient } from 'sanity:client';

// Отримуємо проєкти з Sanity
const projects = await sanityClient.fetch(`
  *[_type == "project"] | order(_createdAt desc) {
    _id,
    titleUa,
    titleEn,
    category,
    "slug": slug.current,
    "mainImageUrl": mainImage.asset->url,
    "coverUrl": coverImage.asset->url,
    "coverAltUrl": cover.asset->url,
    "galleryUrls": gallery[].asset->url
  }
`);

// Отримуємо налаштування сайту
const settings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    "heroImageUrl": heroImage.asset->url,
    "aboutImageUrl": aboutImage.asset->url,
    photographerName,
    aboutTextUa,
    aboutTextEn
  }
`);

const heroImage = settings?.heroImageUrl || projects[0]?.mainImageUrl || projects[0]?.coverUrl || projects[0]?.coverAltUrl || projects[0]?.galleryUrls?.[0];
const aboutImage = settings?.aboutImageUrl;
const name = settings?.photographerName || 'Maryna M';

const aboutUa = settings?.aboutTextUa || "Моя мета — зберігати щирі емоції, естетику моменту та унікальну атмосферу кожної зйомки.";
const aboutEn = settings?.aboutTextEn || "My goal is to capture genuine emotions, aesthetic moments, and the unique atmosphere of every photoshoot.";
---

<html lang="uk" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{name} | Portfolio</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Montserrat:wght@200;300;400;500&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#f7f5f0] text-[#2c2a29] antialiased selection:bg-[#d8c3b0]">

    <!-- ШАПКА / НАВІГАЦІЯ -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white/60 backdrop-blur-md border-b border-stone-200/50">
      <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="font-serif text-xl md:text-2xl tracking-widest uppercase font-light">
          PHOTOGRAPHER
        </a>

        <!-- Декстопне меню -->
        <nav class="hidden md:flex items-center gap-8 text-xs uppercase tracking-widest text-stone-600 font-light">
          <a href="#gallery" data-i18n-ua="Галерея" data-i18n-en="Gallery" class="hover:text-black transition">Галерея</a>
          <a href="#about" data-i18n-ua="Про мене" data-i18n-en="About" class="hover:text-black transition">Про мене</a>
          <a href="#price" data-i18n-ua="Прайс" data-i18n-en="Price" class="hover:text-black transition">Прайс</a>
          <a href="#contact" data-i18n-ua="Контакти" data-i18n-en="Contacts" class="hover:text-black transition">Контакти</a>
        </nav>

        <!-- Декстопний перемикач мов -->
        <div class="hidden md:flex items-center gap-2 text-xs font-light tracking-wider text-stone-500">
          <button class="lang-ua font-bold text-black underline underline-offset-4 cursor-pointer">UA</button>
          <span>|</span>
          <button class="lang-en hover:text-black cursor-pointer">EN</button>
        </div>

        <!-- Гамбургер меню -->
        <button id="mobile-menu-btn" class="md:hidden text-2xl p-1 focus:outline-none" aria-label="Toggle Menu">
          ☰
        </button>
      </div>

      <!-- Мобільне меню -->
      <div id="mobile-menu" class="hidden md:hidden bg-white/95 backdrop-blur-lg border-b border-stone-200 px-6 py-6 flex-col gap-4 text-center">
        <a href="#gallery" data-i18n-ua="Галерея" data-i18n-en="Gallery" class="mobile-link text-sm uppercase tracking-widest text-stone-700 py-2">Галерея</a>
        <a href="#about" data-i18n-ua="Про мене" data-i18n-en="About" class="mobile-link text-sm uppercase tracking-widest text-stone-700 py-2">Про мене</a>
        <a href="#price" data-i18n-ua="Прайс" data-i18n-en="Price" class="mobile-link text-sm uppercase tracking-widest text-stone-700 py-2">Прайс</a>
        <a href="#contact" data-i18n-ua="Контакти" data-i18n-en="Contacts" class="mobile-link text-sm uppercase tracking-widest text-stone-700 py-2">Контакти</a>
        
        <div class="pt-4 border-t border-stone-200 flex justify-center gap-4 text-sm">
          <button class="lang-ua font-bold text-black underline underline-offset-4 cursor-pointer">UA</button>
          <span>|</span>
          <button class="lang-en text-stone-500 cursor-pointer">EN</button>
        </div>
      </div>
    </header>

    <!-- HERO БАНЕР -->
    <section class="relative w-full h-screen flex items-center justify-center overflow-hidden">
      {heroImage ? (
        <img src={heroImage} alt="Hero Background" class="absolute inset-0 w-full h-full object-cover filter brightness-[0.85]" />
      ) : (
        <div class="absolute inset-0 bg-stone-300"></div>
      )}
      <div class="absolute inset-0 bg-black/25"></div>

      <div class="relative z-10 text-center text-white px-4 max-w-3xl">
        <p class="text-xs uppercase tracking-[0.3em] font-light mb-4 text-stone-200">Visual Artist & Photographer</p>
        <h1 class="font-serif text-4xl sm:text-6xl md:text-7xl font-light italic tracking-wide drop-shadow-md mb-6">
          {name}
        </h1>
        <div class="flex flex-col sm:flex-row justify-center gap-4 mt-8">
          <a href="#gallery" data-i18n-ua="Переглянути роботи" data-i18n-en="View Works" class="px-8 py-3 bg-white/90 text-stone-900 text-xs uppercase tracking-widest hover:bg-white transition rounded-full shadow-lg">
            Переглянути роботи
          </a>
          <a href="#contact" data-i18n-ua="Замовити зйомку" data-i18n-en="Book a Session" class="px-8 py-3 border border-white/70 text-white text-xs uppercase tracking-widest hover:bg-white/10 transition rounded-full">
            Замовити зйомку
          </a>
        </div>
      </div>
    </section>

    <!-- СІТКА ГАЛЕРЕЇ -->
    <section id="gallery" class="max-w-7xl mx-auto px-6 py-20">
      <div class="text-center mb-12">
        <span class="text-xs uppercase tracking-[0.25em] text-stone-400">Portfolio</span>
        <h2 data-i18n-ua="Серії та Фотопроєкти" data-i18n-en="Series & Photo Projects" class="font-serif text-3xl md:text-4xl font-light mt-2 italic">
          Серії та Фотопроєкти
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project: any) => {
          const chosenCover = project.mainImageUrl || project.coverUrl || project.coverAltUrl || project.galleryUrls?.[0];
          
          return (
            <a href={`/projects/${project.slug}`} class="group block bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition duration-500 border border-stone-200/60">
              <div class="relative h-80 sm:h-96 overflow-hidden bg-stone-100">
                {chosenCover ? (
                  <img src={chosenCover} alt={project.titleUa} class="w-full h-full object-cover group-hover:scale-105 transition duration-700" />
                ) : (
                  <div class="w-full h-full bg-stone-200 flex items-center justify-center text-xs text-stone-400">
                    Немає зображення
                  </div>
                )}
              </div>
              <div class="p-6">
                <span class="text-[10px] uppercase tracking-[0.2em] text-stone-400 font-medium">{project.category || 'Portfolio'}</span>
                <h3 
                  data-title-ua={project.titleUa} 
                  data-title-en={project.titleEn || project.titleUa} 
                  class="project-title font-serif text-2xl font-light text-stone-800 mt-1"
                >
                  {project.titleUa}
                </h3>
                <div class="mt-4 pt-4 border-t border-stone-100 flex justify-between items-center text-xs text-stone-500 font-light">
                  <span data-i18n-ua="Переглянути серію" data-i18n-en="View Series">Переглянути серію</span>
                  <span class="group-hover:translate-x-1 transition-transform">→</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- СЕКЦІЯ "ПРО МЕНЕ" -->
    <section id="about" class="bg-[#efece6] py-24 border-t border-stone-200/60">
      <div class={`max-w-5xl mx-auto px-6 ${aboutImage ? 'grid grid-cols-1 md:grid-cols-2 gap-12 items-center' : 'text-center max-w-2xl'}`}>
        <div>
          <span class="text-xs uppercase tracking-[0.25em] text-stone-400">About</span>
          <h2 data-i18n-ua="Про автора" data-i18n-en="About the Author" class="font-serif text-3xl md:text-4xl font-light mt-2 italic">
            Про автора
          </h2>
          <p 
            data-i18n-ua={aboutUa} 
            data-i18n-en={aboutEn} 
            class="text-sm leading-relaxed text-stone-600 mt-6 font-light"
          >
            {aboutUa}
          </p>
        </div>

        {aboutImage && (
          <div class="relative flex justify-center">
            <img 
              src={aboutImage} 
              alt="About photographer" 
              class="w-80 h-96 object-cover rounded-lg shadow-xl border-4 border-white"
            />
          </div>
        )}
      </div>
    </section>

    <!-- КЛІЄНТСЬКИЙ СКРИПТ ПЕРЕКЛАДУ -->
    <script>
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
        mobileMenu?.classList.toggle('flex');
      });

      document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('hidden');
          mobileMenu?.classList.remove('flex');
        });
      });

      function switchLanguage(lang: 'ua' | 'en') {
        // Оновлюємо вигляд кнопок
        document.querySelectorAll('.lang-ua').forEach(btn => {
          if (lang === 'ua') btn.classList.add('font-bold', 'text-black', 'underline', 'underline-offset-4');
          else btn.classList.remove('font-bold', 'text-black', 'underline', 'underline-offset-4');
        });

        document.querySelectorAll('.lang-en').forEach(btn => {
          if (lang === 'en') btn.classList.add('font-bold', 'text-black', 'underline', 'underline-offset-4');
          else btn.classList.remove('font-bold', 'text-black', 'underline', 'underline-offset-4');
        });

        // Перекладаємо текстові блоки
        document.querySelectorAll('[data-i18n-ua]').forEach((el) => {
          const target = el as HTMLElement;
          const text = target.getAttribute(`data-i18n-${lang}`);
          if (text) target.textContent = text;
        });

        // Перекладаємо заголовки фотопроєктів
        document.querySelectorAll('.project-title').forEach((el) => {
          const target = el as HTMLElement;
          const title = target.getAttribute(`data-title-${lang}`);
          if (title) target.textContent = title;
        });

        localStorage.setItem('preferred_lang', lang);
      }

      document.querySelectorAll('.lang-ua').forEach(btn => btn.addEventListener('click', () => switchLanguage('ua')));
      document.querySelectorAll('.lang-en').forEach(btn => btn.addEventListener('click', () => switchLanguage('en')));

      const savedLang = (localStorage.getItem('preferred_lang') as 'ua' | 'en') || 'ua';
      switchLanguage(savedLang);
    </script>
  </body>
</html>