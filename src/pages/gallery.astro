---
import { sanityClient } from 'sanity:client';

const projects = await sanityClient.fetch(`
  *[_type == "project"] | order(_createdAt desc) {
    _id,
    titleUa,
    titleEn,
    category,
    descriptionUa,
    descriptionEn,
    "slug": slug.current,
    "mainImageUrl": mainImage.asset->url,
    "galleryUrls": gallery[].asset->url
  }
`);

const categoryTranslations: Record<string, { ua: string; en: string }> = {
  portrait: { ua: 'Портрет', en: 'Portrait' },
  fashion: { ua: 'Фешн', en: 'Fashion' },
  studio: { ua: 'Студійна', en: 'Studio' },
  lovestory: { ua: 'Love Story', en: 'Love Story' },
  wedding: { ua: 'Весільна', en: 'Wedding' },
};
---

<html lang="uk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Галерея | Portfolio</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Montserrat:wght@200;300;400;500&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#f7f5f0] text-[#2c2a29] min-h-screen">

    <header class="p-6 max-w-7xl mx-auto flex justify-between items-center">
      <a href="/" data-i18n-ua="← На головну" data-i18n-en="← Back to home" class="text-xs uppercase tracking-widest text-stone-500 hover:text-black transition">
        ← На головну
      </a>
      <div class="flex gap-2 text-xs text-stone-500">
        <button class="lang-ua font-bold text-black underline underline-offset-4 cursor-pointer">UA</button>
        <span>|</span>
        <button class="lang-en hover:text-black cursor-pointer">EN</button>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-12">
      <div class="text-center mb-16">
        <span class="text-xs uppercase tracking-[0.25em] text-stone-400">All Works</span>
        <h1 data-i18n-ua="Портфоліо & Серії" data-i18n-en="Portfolio & Series" class="font-serif text-4xl md:text-5xl font-light italic mt-2">
          Портфоліо & Серії
        </h1>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project: any) => {
          const chosenCover = project.mainImageUrl || project.galleryUrls?.[0];
          const catKey = (project.category || '').toLowerCase();
          const catUa = categoryTranslations[catKey]?.ua || project.category || 'Портфоліо';
          const catEn = categoryTranslations[catKey]?.en || project.category || 'Portfolio';

          return (
            <a href={`/projects/${project.slug}`} class="group block bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition duration-500 border border-stone-200/60">
              <div class="relative h-80 sm:h-96 overflow-hidden bg-stone-100">
                {chosenCover && (
                  <img src={chosenCover} alt={project.titleUa} class="w-full h-full object-cover group-hover:scale-105 transition duration-700" />
                )}
              </div>
              <div class="p-6">
                <span data-cat-ua={catUa} data-cat-en={catEn} class="project-category text-[10px] uppercase tracking-[0.2em] text-stone-400 font-medium">
                  {catUa}
                </span>

                <h2 data-title-ua={project.titleUa} data-title-en={project.titleEn || project.titleUa} class="project-title font-serif text-2xl font-light text-stone-800 mt-1">
                  {project.titleUa}
                </h2>

                <div class="mt-4 pt-4 border-t border-stone-100 flex justify-between items-center text-xs text-stone-500 font-light">
                  <span data-i18n-ua="Переглянути серію" data-i18n-en="View Series">Переглянути серію</span>
                  <span>→</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </main>

    <script>
      function switchLanguage(lang: 'ua' | 'en') {
        document.querySelectorAll('.lang-ua').forEach(btn => {
          if (lang === 'ua') btn.classList.add('font-bold', 'text-black', 'underline', 'underline-offset-4');
          else btn.classList.remove('font-bold', 'text-black', 'underline', 'underline-offset-4');
        });

        document.querySelectorAll('.lang-en').forEach(btn => {
          if (lang === 'en') btn.classList.add('font-bold', 'text-black', 'underline', 'underline-offset-4');
          else btn.classList.remove('font-bold', 'text-black', 'underline', 'underline-offset-4');
        });

        document.querySelectorAll('[data-i18n-ua]').forEach((el) => {
          const target = el as HTMLElement;
          const text = target.getAttribute(`data-i18n-${lang}`);
          if (text) target.textContent = text;
        });

        document.querySelectorAll('.project-category').forEach((el) => {
          const target = el as HTMLElement;
          const cat = target.getAttribute(`data-cat-${lang}`);
          if (cat) target.textContent = cat;
        });

        document.querySelectorAll('.project-title').forEach((el) => {
          const target = el as HTMLElement;
          const title = target.getAttribute(`data-title-${lang}`);
          if (title) target.textContent = title;
        });

        localStorage.setItem('preferred_lang', lang);
      }

      document.querySelectorAll('.lang-ua').forEach(btn => btn.addEventListener('click', () => switchLanguage('ua')));
      document.querySelectorAll('.lang-en').forEach(btn => btn.addEventListener('click', () => switchLanguage('en')));

      const savedLang = (localStorage.getItem('preferred_lang') as 'ua' | 'en') || 'ua';
      switchLanguage(savedLang);
    </script>
  </body>
</html>