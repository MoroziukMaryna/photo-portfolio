---
import { sanityClient } from 'sanity:client';

const settings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    "aboutImageUrl": aboutImage.asset->url,
    photographerName,
    aboutTextUa,
    aboutTextEn,
    instagram, telegram, email, phone
  }
`);

const name = settings?.photographerName || 'Maryna M';
const aboutImage = settings?.aboutImageUrl;
const aboutUa = settings?.aboutTextUa || "Моя мета — зберігати щирі емоції, естетику моменту та унікальну атмосферу кожної зйомки.";
const aboutEn = settings?.aboutTextEn || "My goal is to capture genuine emotions, aesthetic moments, and the unique atmosphere of every photoshoot.";
---

<html lang="uk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Про автора | Portfolio</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Montserrat:wght@200;300;400;500&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#f7f5f0] text-[#2c2a29] min-h-screen flex flex-col justify-between">

    <header class="p-6 max-w-7xl mx-auto w-full flex justify-between items-center">
      <a href="/" data-i18n-ua="← На головну" data-i18n-en="← Back to home" class="text-xs uppercase tracking-widest text-stone-500 hover:text-black transition">
        ← На головну
      </a>
      <div class="flex gap-2 text-xs text-stone-500">
        <button class="lang-ua font-bold text-black underline underline-offset-4 cursor-pointer">UA</button>
        <span>|</span>
        <button class="lang-en hover:text-black cursor-pointer">EN</button>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-12 w-full">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        {aboutImage && (
          <div class="flex justify-center">
            <img src={aboutImage} alt="About Photographer" class="w-80 h-[450px] object-cover rounded-2xl shadow-xl border-4 border-white" />
          </div>
        )}

        <div>
          <span class="text-xs uppercase tracking-[0.25em] text-stone-400">About Author</span>
          <h1 class="font-serif text-4xl md:text-5xl font-light italic mt-2 mb-6">{name}</h1>
          
          <p data-i18n-ua={aboutUa} data-i18n-en={aboutEn} class="text-sm leading-relaxed text-stone-600 font-light mb-8">
            {aboutUa}
          </p>

          <!-- Контакти -->
          <div class="border-t border-stone-200/80 pt-8 grid grid-cols-2 gap-6">
            {settings?.instagram && (
              <div>
                <span class="text-[10px] uppercase tracking-widest text-stone-400 block">Instagram</span>
                <a href={settings.instagram.startsWith('http') ? settings.instagram : `https://instagram.com/${settings.instagram.replace('@', '')}`} target="_blank" class="text-xs font-light text-stone-800 hover:underline">
                  {settings.instagram}
                </a>
              </div>
            )}

            {settings?.telegram && (
              <div>
                <span class="text-[10px] uppercase tracking-widest text-stone-400 block">Telegram</span>
                <a href={settings.telegram.startsWith('http') ? settings.telegram : `https://t.me/${settings.telegram.replace('@', '')}`} target="_blank" class="text-xs font-light text-stone-800 hover:underline">
                  {settings.telegram}
                </a>
              </div>
            )}

            {settings?.email && (
              <div>
                <span class="text-[10px] uppercase tracking-widest text-stone-400 block">Email</span>
                <a href={`mailto:${settings.email}`} class="text-xs font-light text-stone-800 hover:underline">
                  {settings.email}
                </a>
              </div>
            )}

            {settings?.phone && (
              <div>
                <span class="text-[10px] uppercase tracking-widest text-stone-400 block" data-i18n-ua="Телефон" data-i18n-en="Phone">Телефон</span>
                <a href={`tel:${settings.phone}`} class="text-xs font-light text-stone-800 hover:underline">
                  {settings.phone}
                </a>
              </div>
            )}
          </div>
        </div>
      </div>
    </main>

    <footer class="p-6 text-center text-[10px] text-stone-400 tracking-widest uppercase">
      © {new Date().getFullYear()} {name}. All rights reserved.
    </footer>

    <script>
      function switchLanguage(lang: 'ua' | 'en') {
        document.querySelectorAll('.lang-ua').forEach(btn => {
          if (lang === 'ua') btn.classList.add('font-bold', 'text-black', 'underline', 'underline-offset-4');
          else btn.classList.remove('font-bold', 'text-black', 'underline', 'underline-offset-4');
        });

        document.querySelectorAll('.lang-en').forEach(btn => {
          if (lang === 'en') btn.classList.add('font-bold', 'text-black', 'underline', 'underline-offset-4');
          else btn.classList.remove('font-bold', 'text-black', 'underline', 'underline-offset-4');
        });

        document.querySelectorAll('[data-i18n-ua]').forEach((el) => {
          const target = el as HTMLElement;
          const text = target.getAttribute(`data-i18n-${lang}`);
          if (text) target.textContent = text;
        });

        localStorage.setItem('preferred_lang', lang);
      }

      document.querySelectorAll('.lang-ua').forEach(btn => btn.addEventListener('click', () => switchLanguage('ua')));
      document.querySelectorAll('.lang-en').forEach(btn => btn.addEventListener('click', () => switchLanguage('en')));

      const savedLang = (localStorage.getItem('preferred_lang') as 'ua' | 'en') || 'ua';
      switchLanguage(savedLang);
    </script>
  </body>
</html>